<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#3A1414" />
            <corners android:radius="16dp" />
            <stroke android:width="1.5dp" android:color="@color/status_offline" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2A1212" />
            <corners android:radius="16dp" />
            <stroke android:width="1.5dp" android:color="#B84A4A" />
        </shape>
    </item>
</selector>
